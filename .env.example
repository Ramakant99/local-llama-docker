# Llama.cpp Dual-Model Configuration
# Copy this file to .env and customize: cp .env.example .env

# The path to your models folder on the host
MODELS_DIR=./models

# --- PLANNER MODEL CONFIGURATION ---
# (Used for high-level planning)
PLANNER_MODEL=your-planner-model.gguf
PLANNER_PORT=8080
PLANNER_THREADS=8
PLANNER_GPU_LAYERS=35
PLANNER_CTX=4096

# --- AGENT MODEL CONFIGURATION ---
# (Used for agent behavior and tool calling)
AGENT_MODEL=your-agent-model.gguf
AGENT_PORT=8081
AGENT_THREADS=4
AGENT_GPU_LAYERS=0
AGENT_CTX=4096

# --- ADVANCED GLOBAL SETTINGS ---
EMBEDDINGS=true
MLOCK=false
NO_MMAP=false
API_KEY=

# --- PERFORMANCE & REASONING (GPU) ---
# Flash Attention: 'true' or 'false'
FLASH_ATTN=true
# KV Cache Quantization: 'q8_0', 'q4_0', or 'f16'
KV_CACHE_QUANT=q8_0
# Batch sizes for prompt processing
BATCH_SIZE=2048
# Reasoning budget for thinking models (-1 for infinite/model default)
REASONING_BUDGET=-1
# Chat Template options (preserves <thought> blocks)
PRESERVE_THINKING=true

# Image tags
IMAGE_TAG_CPU=server
IMAGE_TAG_GPU=server-cuda
